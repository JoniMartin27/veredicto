diff --git a/src/discount.js b/src/discount.js
--- a/src/discount.js
+++ b/src/discount.js
@@ -1,3 +1,8 @@
 'use strict';
+function applyDiscount(price, pct) {
+  if (pct < 0 || pct > 100) throw new RangeError('pct out of range');
+  return price - (price * pct) / 100;
+}
+module.exports = { applyDiscount };
diff --git a/test/discount.test.js b/test/discount.test.js
--- a/test/discount.test.js
+++ b/test/discount.test.js
@@ -1,3 +1,9 @@
 'use strict';
+const { applyDiscount } = require('../src/discount');
+const assert = require('node:assert');
+const { test } = require('node:test');
+test('applies a 10% discount', () => {
+  assert.equal(applyDiscount(100, 10), 90);
+});
